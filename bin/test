#!/bin/bash
# AI/Codex 向け実行メモ:
# - どのディレクトリから実行しても、スクリプト自身がリポジトリルートへ移動します。
# - Codex の sandbox 環境では、次のように実行します:
#   `SWIFTPM_MODULECACHE_OVERRIDE="$PWD/.build/codex-cache/clang-module-cache" bin/test --disable-sandbox`
# - `--disable-sandbox` はこのスクリプトが消費し、`swift package resolve` にだけ転送します。
# - その他の引数は最後に実行する OpenXLSXTests へ転送します。

set -eu

script_dir=$(cd "$(dirname "$0")" && pwd)
repo_root=$(cd "$script_dir/.." && pwd)
cd "$repo_root"

build_dir=${OPENXLSX_CMAKE_BUILD_DIR:-"$repo_root/build/ninja-tests"}
swiftpm_build_dir=${OPENXLSX_SWIFTPM_BUILD_DIR:-"$repo_root/.build"}
swiftpm_checkouts_dir="$swiftpm_build_dir/checkouts"
pugixml_source_dir=${OPENXLSX_PUGIXML_SOURCE_DIR:-"$swiftpm_checkouts_dir/pugixml"}
miniz_source_dir=${OPENXLSX_MINIZ_SOURCE_DIR:-"$swiftpm_checkouts_dir/miniz"}

swift_package_args=()
test_args=()
while (($#)); do
    case "$1" in
        --disable-sandbox)
            swift_package_args+=("--disable-sandbox")
            ;;
        *)
            test_args+=("$1")
            ;;
    esac
    shift
done

if ((${#swift_package_args[@]})); then
    swift package "${swift_package_args[@]}" resolve
else
    swift package resolve
fi

if [[ ! -d "$pugixml_source_dir" ]]; then
    echo "error: pugixml checkout not found: $pugixml_source_dir" >&2
    exit 1
fi

if [[ ! -d "$miniz_source_dir" ]]; then
    echo "error: miniz checkout not found: $miniz_source_dir" >&2
    exit 1
fi

cmake -S . -B "$build_dir" -G Ninja \
    -DCMAKE_BUILD_TYPE=Debug \
    -DOPENXLSX_BUILD_TESTS=ON \
    -DOPENXLSX_CREATE_DOCS=OFF \
    -DOPENXLSX_BUILD_SAMPLES=OFF \
    -DFETCHCONTENT_SOURCE_DIR_PUGIXML_FETCH="$pugixml_source_dir" \
    -DFETCHCONTENT_SOURCE_DIR_MINIZ_FETCH="$miniz_source_dir"

cmake --build "$build_dir" --target OpenXLSXTests --parallel

if ((${#test_args[@]})); then
    "$build_dir/output/OpenXLSXTests" "${test_args[@]}"
else
    "$build_dir/output/OpenXLSXTests"
fi
